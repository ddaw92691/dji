# 请求基础地址（直接指向后端公开地址，与 merchant-web / customer-web 保持一致）
# 原值为相对路径 "/api"，依赖前端容器内 nginx 反向代理到 127.0.0.1:8080，
# 在 Railway 拆分服务部署下后端不在同一容器内，会导致登录及所有接口请求失败。
VITE_API_BASE_URL="https://dji-api.up.railway.app/api"
# 静态资源前缀路径
VITE_STATIC_URL="/"
# WebSocket 地址（与后端同源，便于实时通知；登录无关，可按需保留）
VITE_WS_URL="https://dji-api.up.railway.app/ws"