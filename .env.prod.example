# ============================================================
# 后端 (apps/api) 生产环境变量清单 —— 部署对照表
# ------------------------------------------------------------
# 这是「需要配哪些变量」的模板，本文件不含任何真实值，可提交到 git。
# 真实值请在 Railway 服务的 Variables 页面填写，永远不要写进仓库。
# 带 [必填] 的变量没有默认值，漏配会导致启动失败。
# ============================================================

# ---- 数据库 (PostgreSQL) ----
DB_HOST=                 # 数据库主机，Railway 内网域名，如 ${{Postgres.PGHOST}}
DB_PORT=                 # 默认 5432
DB_NAME=                 # 库名，默认 mall_system
DB_USERNAME=             # 默认 mall_user
DB_PASSWORD=             # [必填] 数据库密码，无默认值

# ---- JWT ----
JWT_SECRET=              # [必填] 鉴权密钥，须为 ≥32 字节的随机串，无默认值
JWT_EXPIRE_SECONDS=      # token 有效期(毫秒)，默认 86400000 (1天)

# ---- CORS ----
# 前端域名白名单，逗号分隔；不配则默认仅允许 http://localhost
CORS_ALLOWED_ORIGINS=    # 如 https://admin.example.com,https://merchant.example.com

# ---- 其它(均有默认值，可不配) ----
SERVER_PORT=             # 服务端口，默认 8080
SWAGGER_ENABLED=         # 是否开放接口文档，默认 false（生产建议保持 false）
UPLOAD_DIR=              # 上传目录，默认 uploads
LOG_LEVEL=               # 日志级别，默认 INFO

# ============================================================
# 生成 JWT_SECRET 的方法(任选其一)：
#   openssl rand -base64 48
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# ============================================================
