# ============================================
# Mall System - Environment Variables
# ============================================
# Copy this file to .env and modify as needed

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mall_system
DB_USER=mall_user
DB_PASSWORD=mall_pass_2024

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=mall-system-jwt-secret-key-2024-please-change-in-production
JWT_EXPIRATION=86400000

# --- Server Ports ---
API_PORT=8080
CUSTOMER_WEB_PORT=4173
MERCHANT_WEB_PORT=5174
ADMIN_WEB_PORT=5175

# --- Logging ---
LOG_LEVEL=DEBUG
